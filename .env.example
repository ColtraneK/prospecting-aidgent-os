# Copy to .env and fill in. NEVER commit .env or any real values.
# .env, credentials, browser profiles, and run artifacts are git-ignored.

# --- Google Sheets (service account, unattended) ---------------------------
# Absolute path to a service-account JSON key file kept OUTSIDE this repo.
# Share the target Sheet with the service account's client_email (Editor).
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/outside/repo/service-account.json
# Spreadsheet id (the long id in the Sheet URL). Persona.sheet_id overrides this.
GOOGLE_SHEET_ID=

# --- Persona ---------------------------------------------------------------
# Active persona slug (file under private/personas/<slug>.yaml).
AIDGENT_PERSONA=

# --- Local Chrome profile (dedicated, signed-in manually) ------------------
# A persistent Chrome user-data dir OUTSIDE this repo. It holds auth cookies,
# so treat it like a credential. Sign in once with: npm run setup-login
AIDGENT_CHROME_PROFILE=/absolute/path/outside/repo/aidgent-chrome-profile
# Installed Chrome channel to drive (chrome | chrome-beta | msedge).
AIDGENT_CHROME_CHANNEL=chrome

# --- Run behavior ----------------------------------------------------------
HEADLESS=false
TARGET_COUNT=25
# Safety: hard cap on profiles inspected per run, and pacing bounds (ms).
AIDGENT_DAILY_CAP=120
AIDGENT_MIN_DELAY_MS=3500
AIDGENT_MAX_DELAY_MS=9000
